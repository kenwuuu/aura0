# Copy this file to `.env` and fill in values for your environment.
# See settings.py for validation/defaults.

# Comma-separated list of Scryfall bulk-data types to fetch and serve.
# Each name must have a matching <name>.ndjson under CARD_JSON_DIR.
# Valid Scryfall types: oracle_cards, unique_artwork, default_cards, all_cards, rulings
BULK_DATA_TYPES=default_cards

# Directory where card JSON/NDJSON files live (relative or absolute).
CARD_JSON_DIR=./cards

# Comma-separated list of allowed CORS origins. Leave unset/empty for "*"
# (note: "*" cannot be combined with credentials).
CORS_ORIGIN=http://localhost:5174

# Optional: comma-separated "from:to" pairs. When a lookup misses in dataset
# "from", retry it in dataset "to". e.g. DATASET_FALLBACKS=oracle_cards:unique_artwork
DATASET_FALLBACKS=

# --- data_updater.py alerting (all optional — see SETUP.md's "Alerting" section) ---

# PostHog: reports data_update_succeeded/data_update_failed events (per-dataset
# card counts, run duration). Unset = tracking disabled.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# healthchecks.io (or any compatible dead-man's-switch): base ping URL for one
# check, e.g. https://hc-ping.com/<uuid>. Unset = disabled.
HEALTHCHECK_PING_URL=

# Sentry: PLUMBED BUT NOT WIRED. Also requires `pip install sentry-sdk`
# (intentionally not in requirements.txt yet — pending decision).
SENTRY_DSN=

{
  "name": "aura",
  "version": "1.0.0",
  "description": "Magic: The Gathering collaboration app with WebRTC and Yjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build:precons": "node scripts/build-precons.mjs",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:smoke": "playwright test --grep @smoke --project=chromium",
    "test:e2e:canary": "playwright test --grep @canary --project=chromium",
    "test:e2e:preview": "playwright test -c playwright.preview.config.ts",
    "verify": "npm run typecheck && npm run test:coverage && npm run build && npm run test:e2e:smoke",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "vitest related --run"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@sentry/react": "^10.25.0",
    "@sentry/vite-plugin": "^4.6.0",
    "@tailwindcss/vite": "^4.2.2",
    "@xyflow/react": "^12.11.1",
    "@y/websocket-server": "^0.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "lucide-react": "^0.554.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "p-queue": "^9.0.0",
    "p-retry": "^7.1.0",
    "pm2": "^6.0.14",
    "posthog-js": "^1.390.2",
    "react": "^19.2.0",
    "react-contenteditable": "^3.3.7",
    "react-dom": "^19.2.0",
    "react-hotkeys-hook": "^5.2.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.2",
    "uuid": "^13.0.0",
    "vanilla-cookieconsent": "^3.1.0",
    "wrangler": "^4.107.0",
    "y-indexeddb": "^9.0.12",
    "y-webrtc": "^10.3.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.27",
    "zustand": "^5.0.8"
  },
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.5",
    "@types/marked": "^5.0.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "baseline-browser-mapping": "^2.10.41",
    "csv-parse": "^7.0.1",
    "dependency-cruiser": "^16.10.4",
    "happy-dom": "20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.56.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "8.0.5",
    "vitest": "^4.1.10"
  }
}

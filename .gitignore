/tmp
/out-tsc

/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/.pnp
.pnp.js

.vscode/*
/signaling_server/node_modules/

.env

# Build output. Regenerated by `npm run build`; Cloudflare Workers Builds runs
# the build itself and uploads ./dist (see wrangler.jsonc `assets.directory`),
# so nothing here belongs in git. This used to be `/dist/index.html`, which
# ignored only the entry file and let the hashed bundles and the copy of
# public/ get committed by accident.
/dist

# Coverage output (`npm run test:coverage`)
/coverage

# Sentry Config File
.env.sentry-build-plugin

# Playwright
node_modules/
/test-results/
/playwright-report/
/playwright-report-preview/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# Local wrangler dev state (miniflare cache, bundled dev entrypoints).
# Regenerated on every `wrangler dev`; nothing here belongs in the repo.
.wrangler/

# Wrangler local secrets. `.dev.vars` is what `wrangler dev` reads; `dev.vars`
# is ignored too because the dotless name is easy to create by accident and it
# holds the same thing — an upstream API credential that must never be
# committed. Production/staging values live in `wrangler secret put`, not here.
.dev.vars
.dev.vars.*
dev.vars
